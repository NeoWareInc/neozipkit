# Dependencies
node_modules/
.yarn/install-state.gz

# Build output
dist/

# Compiled example files (examples use ts-node, no compilation needed)
examples/**/*.js
examples/**/*.js.map
examples/**/*.d.ts
examples/**/*.d.ts.map

# Test coverage
coverage/

# IDE
.idea/
.vscode/
*.swp
*.swo
.DS_Store

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment files
.env
.env.local
.env.*.local

# Wallet files (NEVER commit these!)
wallet/
*.wallet
*.keystore
neozip-wallet.json

# Temporary files
*.tmp
*.temp
.cache/

# Example output files (generated by examples)
examples/output/

# Contract artifacts from Hardhat
contracts/artifacts/
contracts/cache/
contracts/typechain/
contracts/typechain-types/

# Deployment files (may contain sensitive data)
contracts/deployment-*.json
contracts/.env
