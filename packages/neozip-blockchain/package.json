{
  "name": "neozip-blockchain",
  "version": "0.7.0",
  "description": "Blockchain functionality for NeoZip and companion to neozipkit — NFT minting, verification, wallet management, OpenTimestamps",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "default": "./dist/core/index.js"
    },
    "./browser": {
      "types": "./dist/browser/index.d.ts",
      "default": "./dist/browser/index.js"
    },
    "./node": {
      "types": "./dist/node/index.d.ts",
      "default": "./dist/node/index.js"
    },
    "./ots": {
      "types": "./dist/ots/index.d.ts",
      "default": "./dist/ots/index.js"
    },
    "./zipstamp-server": {
      "types": "./dist/zipstamp-server/index.d.ts",
      "default": "./dist/zipstamp-server/index.js"
    },
    "./constants/metadata": {
      "types": "./dist/constants/metadata.d.ts",
      "default": "./dist/constants/metadata.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "compile": "tsc",
    "build": "npm run clean && npm run compile",
    "watch": "tsc --watch",
    "test": "jest",
    "test:unit": "jest tests/unit",
    "test:watch": "jest --watch",
    "verify-email": "dotenv -e .env.local -e .env -- ts-node examples/verify-email.ts",
    "example:token-direct": "dotenv -e .env.local -e .env -- ts-node examples/token-direct.ts",
    "example:verify-token": "ts-node examples/verify-token.ts",
    "example:timestamp": "dotenv -e .env.local -e .env -- ts-node examples/stamp-zip.ts examples/output/stamp.nzip examples/test-files/*",
    "example:verify-timestamp": "dotenv -e .env.local -e .env -- ts-node examples/verify-zip.ts examples/output/stamp.nzip",
    "example:upgrade": "dotenv -e .env.local -e .env -- ts-node examples/upgrade-zip.ts examples/output/stamp.nzip",
    "example:verify-upgrade": "dotenv -e .env.local -e .env -- ts-node examples/verify-zip.ts examples/output/stamp-upgrade.nzip",
    "example:mint-nft": "dotenv -e .env.local -e .env -- ts-node examples/mint-nft.ts examples/output/stamp-upgrade.nzip",
    "example:verify-nft": "dotenv -e .env.local -e .env -- ts-node examples/verify-zip.ts examples/output/stamp-upgrade-nft.nzip",
    "example:token-srv": "dotenv -e .env.local -e .env -- ts-node examples/token-create.ts examples/output/token-test.nzip examples/test-files/*",
    "example:ots-stamp": "ts-node examples/ots-stamp-zip.ts examples/output/ots.nzip examples/test-files/*",
    "example:ots-verify": "ts-node examples/ots-verify-zip.ts examples/output/ots.nzip"
  },
  "keywords": [
    "blockchain",
    "nft",
    "ethereum",
    "base",
    "opentimestamps",
    "wallet",
    "verification",
    "minting",
    "zip",
    "neozip",
    "neozipkit"
  ],
  "author": "NeoWare, Inc.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NeoWareInc/neozipkit.git",
    "directory": "packages/neozip-blockchain"
  },
  "bugs": {
    "url": "https://github.com/NeoWareInc/neozipkit/issues"
  },
  "homepage": "https://github.com/NeoWareInc/neozipkit/tree/main/packages/neozip-blockchain#readme",
  "license": "MIT",
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^25.0.3",
    "dotenv": "^16.4.5",
    "dotenv-cli": "^7.4.2",
    "jest": "^29.7.0",
    "jest-util": "^30.2.0",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "ethers": "^6.0.0",
    "moment-timezone": "^0.6.0",
    "neozipkit": "workspace:*",
    "opentimestamps": "^0.4.9"
  },
  "peerDependencies": {
    "neozipkit": "^0.7.0"
  },
  "peerDependenciesMeta": {
    "neozipkit": {
      "optional": false
    }
  }
}
