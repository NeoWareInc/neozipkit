{
  "private": true,
  "name": "neozipkit-monorepo",
  "version": "0.7.0",
  "packageManager": "yarn@4.12.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "yarn workspaces foreach -A -t run build",
    "test": "yarn workspaces foreach -A run test",
    "test:unit": "yarn workspaces foreach -A run test:unit",
    "clean": "yarn workspaces foreach -A run clean",
    "version:set": "node scripts/version-sync.js",
    "version:patch": "node scripts/version-sync.js patch",
    "version:minor": "node scripts/version-sync.js minor",
    "version:major": "node scripts/version-sync.js major",
    "publish:all": "bash scripts/publish-all.sh"
  }
}
